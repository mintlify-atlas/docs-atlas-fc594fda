            ]
          },
          {
            "group": "Development",
            "pages": [
              "development/setup",
              "development/architecture",
              "development/state-management",
              "development/api-integration"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Services",
            "pages": [
              "api/expenses-service",
              "api/accounts-service",
